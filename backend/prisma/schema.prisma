generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GESTOR
  FUNCIONARIO
}

enum MissionType {
  STANDARD
  WEEKLY_DAILY
}

model User {
  id                Int                @id @default(autoincrement())
  name              String
  email             String             @unique
  password          String
  role              Role
  points            Int                @default(0)
  currentStreak     Int                @default(0)
  longestStreak     Int                @default(0)
  lastActivityDate  DateTime?
  createdAt         DateTime           @default(now())
  transactions      PointTransaction[]
  feedbacks         Feedback[]
  rewardRedemptions RewardRedemption[]
  missionBonuses    MissionBonus[]
}

model Reward {
  id                       Int                @id @default(autoincrement())
  title                    String
  description              String
  cost                     Int
  quantity                 Int
  active                   Boolean            @default(true)
  allowMultipleRedemptions Boolean            @default(false)
  createdAt                DateTime           @default(now())
  redemptions              RewardRedemption[]
}

model RewardRedemption {
  id        Int      @id @default(autoincrement())
  userId    Int
  rewardId  Int
  cost      Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Mission {
  id                  Int                @id @default(autoincrement())
  title               String
  description         String
  points              Int
  active              Boolean            @default(true)
  type                MissionType        @default(STANDARD)
  startDate           DateTime?
  endDate             DateTime?
  bonusPercentage     Int?
  requiredCompletions Int?
  createdAt           DateTime           @default(now())
  transactions        PointTransaction[]
  bonuses             MissionBonus[]
}

model MissionBonus {
  id        Int      @id @default(autoincrement())
  userId    Int
  missionId Int
  points    Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])
}

model PointTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  missionId Int
  points    Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])
}
